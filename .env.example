# ai-video-router — local-only environment.
# Copy to .env.local (gitignored) and fill in whichever keys you have.

# Router provider. Optional: auto-detected from the first present key below.
# Values: cerebras | groq
# ROUTER_PROVIDER=cerebras

# Cerebras key (https://inference.cerebras.ai). Default model: llama-3.3-70b.
# CEREBRAS_API_KEY=

# Groq key (https://console.groq.com). Default model: llama-3.3-70b-versatile.
# GROQ_API_KEY=

# Override the router model if needed.
# ROUTER_MODEL=llama-3.3-70b

# The editing session reads ANTHROPIC_API_KEY from env if set; otherwise it
# inherits your local `~/.claude/` auth (Claude Code login). Leave unset in
# local dev to use your subscription for free.
# ANTHROPIC_API_KEY=
