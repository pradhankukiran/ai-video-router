# ai-video-router — local-only environment.
# Copy to .env.local (gitignored) and fill in the values below.

# Groq key (https://console.groq.com).
# Default model: meta-llama/llama-4-scout-17b-16e-instruct.
GROQ_API_KEY=

# Override the router model if needed.
# ROUTER_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# The editing session reads ANTHROPIC_API_KEY from env if set; otherwise it
# inherits your local `~/.claude/` auth (Claude Code login). Leave unset in
# local dev to use your subscription for free.
# ANTHROPIC_API_KEY=

# Strict session mode. When set to "1", the Claude Code session cannot use
# the Bash tool at all — Read/Edit/Write remain path-sandboxed to the
# project dir. Recommended for demos or when you don't want to rely on
# Bash's best-effort deny-list.
# AVR_STRICT=1
